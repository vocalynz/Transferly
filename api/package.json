{
  "name": "transferly-api",
  "version": "1.0.0",
  "private": true,
  "description": "Transferly production-grade payments, invoicing, payouts, and wallet backend",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon app.js",
    "dev:worker": "nodemon jobs/worker.js",
    "start": "node app.js",
    "worker": "node jobs/worker.js",
    "db:migrate": "node db/migrate.js",
